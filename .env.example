# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Telegram user_id админов/HR через запятую
ADMIN_IDS=123456789,987654321

# Строка подключения к БД (по умолчанию SQLite).
# Для Postgres: postgresql+asyncpg://user:password@localhost:5432/horecakadr
DATABASE_URL=sqlite+aiosqlite:///bot.db

# Часовой пояс для собеседований и аналитики
TIMEZONE=Asia/Tashkent

# Заглушка (тех. работы): 1 = бот приостановлен для ВСЕХ (включая админов).
# Включить — поставить 1 и перезапустить бота; выключить — убрать строку/поставить 0.
MAINTENANCE_MODE=0
